# Server config
PORT=8787
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# X (Twitter) API v2 — get from https://developer.x.com/en/portal/dashboard
# Basic plan ($200/mo) gives access to users/by/username and users/:id/tweets
X_BEARER_TOKEN=

# Altura snapshot API — for special PNL cards (Altura holders only)
ALTURA_API_URL=https://avlt-snapshot.vercel.app
ALTURA_API_KEY=

# Postgres for raffle / share tracking. Leave empty to disable.
DATABASE_URL=postgres://altura_persona:CHANGE_ME@127.0.0.1:5432/altura_persona

# Bearer token required by /api/admin/shares.csv. Generate with `openssl rand -hex 32`.
ADMIN_TOKEN=
