# Server config
PORT=8787
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# X (Twitter) API v2 — get from https://developer.x.com/en/portal/dashboard
# Basic plan ($200/mo) gives access to users/by/username and users/:id/tweets
X_BEARER_TOKEN=

# Altura snapshot API — for special PNL cards (Altura holders only)
ALTURA_API_URL=https://avlt-snapshot.vercel.app
ALTURA_API_KEY=
